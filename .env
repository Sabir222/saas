# Environment Variables

# PostgreSQL Service Configuration (Docker Compose credentials)
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# PostgreSQL database connection string (Docker Compose default)
POSTGRES_URL=postgresql://user:password@localhost:5432/saas_db

# Better Auth Configuration
BETTER_AUTH_SECRET=supersecuresecretkey
BETTER_AUTH_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
