FROM postgres:18

# Install hypopg for hypothetical indexes
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    postgresql-18-hypopg \
    && rm -rf /var/lib/apt/lists/*

# Create a custom entrypoint that sets shared_preload_libraries
RUN echo '#!/bin/bash\n\
export POSTGRES_INITDB_ARGS="--allow-pg-stat-statements"\n\
exec docker-entrypoint.sh "$@"' > /entrypoint.sh && \
    chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["postgres"]
