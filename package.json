{
  "name": "saas",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "deploy": "bun run db:migrate && bun run build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "check:types": "tsc --noEmit",
    "postinstall": "bunx lefthook install",
    "lefthook": "lefthook",
    "commitmsg": "commitlint --edit",
    "db:clear": "bun run scripts/clear-db.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "bun run check-db",
    "test:vitest": "vitest",
    "test:vitest:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check-db": "bun run tsx scripts/check-db.ts",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@better-auth/cli": "^1.4.21",
    "@better-auth/drizzle-adapter": "^1.5.4",
    "@better-auth/passkey": "^1.5.4",
    "@logtape/logtape": "^2.0.4",
    "@react-email/components": "^1.0.8",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "2.15.4",
    "resend": "^6.9.3",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@eslint/eslintrc": "^3",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/nextjs-vite": "^10.3.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-storybook": "^10.3.1",
    "knip": "^5.86.0",
    "lint-staged": "^16.4.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.3.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.0.18"
  }
}
