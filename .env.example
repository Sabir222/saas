# PostgreSQL Service Configuration (Docker Compose credentials)
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# PostgreSQL database connection string (Docker Compose default)
POSTGRES_URL=postgresql://user:password@localhost:5432/dev_db

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-character-secret
BETTER_AUTH_URL=http://localhost:3000

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
